# Environment mode: development, test, production
NODE_ENV=development

# Gateway server config
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=3001

# Logging
GATEWAY_LOG_LEVEL=info

# Config validation strictness
GATEWAY_CONFIG_STRICT=true

# OpenCode SDK adapter (disabled by default)
# To enable, set OPENCODE_SDK_ENABLED=true and provide server URL and model
OPENCODE_SDK_ENABLED=false
OPENCODE_SERVER_URL=
OPENCODE_DEFAULT_MODEL=
